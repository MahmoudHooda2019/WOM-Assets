            "hint":"يمكنك تجنيد فارس الليل في مبنى مركز التجنيد. بمجرد تجنيدهم ستتمكن من توظيفهم للحرب في منطقة التوظيف.",
            "title":"وظف عدد 1 فارس ليل"
        },
        "9003":{
            "gototext":"أرِني",
            "hint":"انقر على زر الحرب ثم على \"حملة\" لتحديد مكان أحد قبائل القبضة الحديدية القريبة. يمكنك استطلاع مدينة العدو قبل بدء الهجوم.",
            "title":"هاجم مركز مدينة إحدى قبائل القبضة الحديدية"
        }
    },
    "tutorial":{
        "done":"موافق",
        "step":{
            "1":{
                "desc":"بسرعة سيدي! قطاع الطرق يهاجمون، دعنا نستولي عليهم!",
                "done":"موافق"
            },
            "10":{
                "desc":"انضم بعض المرتزقة إلى قضيتنا."
            },
            "11":{
                "desc":"الدفاع جيد! دعنا ننتقم من قطاع الطرق الذين هاجموك!"
            },
            "11b":{
                "desc":"العدو يقيم الخيام خارج مدينتنا. لنذهب ونسحقهم!"
            },
            "14-alt":{
                "desc":"هذه المدينة ليس بها سوى دفاعات قليلة. لنهاجمها!"
            },
            "14":{
                "desc":"هذه المدينة ليست بها دفاعات. لنهاجمها!",
                "done":"مرحبا!"
            },
            "15-alt":{
                "desc":" انقر فوق زر \"+\" لاختيار المرتزقة."
            },
            "15-alt2":{
                "desc":"انقر لاختيار مرتزقة."
            },
            "15":{
                "desc":"انقر مع الاستمرار على زر \"+\" لاختيار المرتزقة."
            },
            "16":{
                "desc":"انقر هنا لنشر المرتزقة!"
            },
            "18":{
                "desc":"انقر على منتجي الموارد لتحصيل الموارد."
            },
            "19":{
                "desc":"الآن لنقم بتطوير أحد المباني!"
            },
            "1b":{
                "desc":"مرحباً سيدي! لقد حان الوقت لترى هذه الأراضي المجد مرة أخرى!",
                "done":"لنبدأ"
            },
            "2":{
                "desc":"لنقم ببناء برج للرماة للدفاع عن المدينة."
            },
            "22":{
                "desc":"انقر على المبنى لتسريع العملية."
            },
            "25":{
                "desc":"هذه هي مهمتنا الأولى. انقر عليها للمتابعة"
            },
            "29":{
                "desc":"ضع منطقة التوظيف الخاصة بك في المكان الذي تريده."
            },
            "32":{
                "desc":"تستغرق عملية البناء هذه 15 دقيقة. دعنا نسرّعها."
            },
            "34":{
                "desc":"الآن لنقم بتوظيف بعض المرتزقة!"
            },
            "36":{
                "desc":"انقر على الصورة 4 مرات لتأجير المحاربين البدو."
            },
            "37":{
                "desc":"سوف ننتظر حتى تكتمل عمليات التوظيف. يمكنك تسريع العملية في \"منطقة التوظيف\" إذا كنت لا ترغب في الانتظار."
            },
            "39":{
                "desc":"أحسنت! دعنا نستأجر عاملاً لبناء المزيد."
            },
            "43":{
                "desc":"أنت محصن ضد الهجمات لفترة من الوقت. المؤقت الموجود بالأعلى يبين المدة.",
                "done":"فهمت!"
            },
            "44":{
                "desc":"اتبع المهام للمضي قدماً. حظاً سعيداً!",
                "done":"اتركني!"
            },
            "45":{
                "desc":"انقر قول المباني التي عليها أيقونات نقاط السمعة. إذا قدمت المساعدة 4 مرات، ستحصل على 4 نقاط سمعة!",
                "done":"رائع"
            },
            "46":{
                "desc":"وجدنا سلعة ثمينة أثناء المعركة. دعنا نلقي نظرة عليها!"
            },
            "47":{
                "desc":"هذا لوح خشبي! هذه الأجزاء ستكون في متناول يديك عندما تبني منتجي موارد.",
                "done":"حقاً؟"
            },
            "5":{
                "desc":"والآن، ضعها هنا."
            },
            "55-1":{
                "done":"فهمت!"
            },
            "55-2":{
                "done":"فهمت!"
            },
            "55":{
                "desc":"هذا يبين نقاط السمعة الحالية التي لديك. يمكنك استخدامه لشراء أصناف من المخزن. اذهب لمساعدة الأصدقاء للحصول على نقاط سمعة!"
            },
            "56":{
                "desc":"المرتزقة الذين تنشرهم ي المعركة لن يعودوا منها بعد أن تنتهي حتى لو نجوا من الموت. لا تنشر مرتزقة أكثر مما تحتاج.",
                "done":"فهمت!"
            },
            "57":{
                "desc":"لا تقلق؛ قريباً سيكون كل شيء بحالة جيدة كما لو كان جديداً. فقط ابدأ الإصلاحات!"
            },
            "58":{
                "desc":"المخزون الخاص بك ممتلئ ولا يمكنك حصاد مواردك. قم ببناء مخزونات احتياطية وتطويرها أو شراء دَفعة للمخزون الاحتياطي."
            },
            "59":{
                "desc":"لقد أطلقت للتو مرتزقاً من النوع الناهب! هذا النوع من المرتزقة ينهبون في الغالب بمعدل 6 أضعاف عند مهاجمة المخزونات الاحتياطية ومراكز المدن."
            },
            "60-1":{
                "done":"يبدو سهلاً!"
            },
            "60-2":{
                "done":"يبدو سهلاً!"
            },
            "60":{
                "desc":"يمكنك تجميع الأجزاء بثلاث طرق: بالنقر على مراكز الأصدقاء، أو إرسال طلبات لهم، أو تدمير مراكز مدن اللاعبين!"
            },
            "61":{
                "desc":"أداؤك ممتاز سيدي! دمّر العدو لتكسب المزيد من الشارات!",
                "done":"رائع!"
            },
            "62":{
                "desc":"يمكنك مشاهدة جميع الأصدقاء واللاعبين الآخرين على خريطتك وفي القائمة.",
                "done":"موافق"
            },
            "63":{
                "desc":"يمكنك أيضاً مهاجمة ونهب قطاع الطرق الهمجيين في وضع \"حملة\"!",
                "done":"فهمت!"
            },
            "64":{
                "desc":"معالجة الأضرار يمنح نقاطاً قتالية؛ المزيد من الأضرار يعني المزيد من النقاط القتالية. هاجم الأصدقاء والقبائل لا يساهم في نقاطك.",
                "done":"فهمت!"
            },
            "65":{
                "desc":"لقد أطلقت للتو مرتزقاً من نوع الدبابة! أرسلهم حتى يهاجموا الأبراج وترد عليهم الأبراج الهجوم! ثم اترك البدو يقومون بالبقية."
            },
            "6b":{
                "desc":"انقر على \"إنهاء مجاني\" فوراً."
            },
            "9":{
                "desc":"مهلاً، بعض قطاع الطرق قادمون! لا تقلق؛ نحن مستعدون جيداً!",
                "done":"أنا مستعد!"
            }
        }
    },
