    "domain":{
        "beasts":{
            "25":{
                "desc":"حرارة الصحراء القاتلة وسيدّه الذي لا يرحم جعلا المخلوق الجباّر يحكم السماء باللهب. تتحدث الأساطير والقصص عن كرات ضخمة من اللهب تترك ورائها طريقاً من الموت في أرض المعركة، لكن لا يستطيع أحدٌ تأكيد وجودها لأنه لم ينجُ من قبضتها حتى الآن أيٌ من أعدائها المرتزقة.",
                "name":"اليعسوب",
                "title":"يمنح القوة للمرتزقة الآخرين"
            },
            "26":{
                "desc":"ليس هناك مخلوق على الأرض لا يمكن لهذا الوحش أن يدهسه، مدفوعاً بسوط سيده الذي لا يرحم. يمثّل جسده الضخم تحدياً دفاعياً لا مثيل له، وتستطيع أنيابه الشريرة أن تقضي على أي خطر في غضون ثوانٍ.",
                "name":"المايتوصور",
                "title":"هجوم عالٍ"
            },
            "27":{
                "desc":"هذا الرمز الأسطوري لروما يهيمن على ساحة المعركة بمخالبه التي تشبه السيوف وأنيابه الحادة كالأمواس. الصفات المتوازنة لهذا الوحش تجعل منه سلاحاً ممتازاً صالحاً لكل الأغراض في أرض المعركة ويريد جميع أمراء الحرب امتلاكه.",
                "name":"مذؤوب",
                "title":"دفاع عالٍ"
            },
            "28":{
                "desc":"?",
                "name":"Womkong",
                "title":"?"
            }
        },
        "building":{
            "10":{
                "desc":"مكان تجمع مواردك، والبوابة المؤدية إلى التقنيات الجديدة، وقلب مدينتك. إذا سقطت فسوف تسقط مدينتك!",
                "name":"مركز المدينة",
                "perlevel":{
                    "10":{
                        "youwillbeabletobuildmore":"-",
                        "youwillbeabletoupgradeyour":"منجرة، محجر، تمثال القوة، معمل صهر الحديد",
                        "youwillunlock":"-"
                    },
                    "2":{
                        "youwillbeabletobuildmore":"منجرة، محجر، تمثال القوة، معمل صهر الحديد، المخزون الاحتياطي، برج الرماة، برج القصف، منطقة التوظيف",
                        "youwillbeabletoupgradeyour":"منجرة، محجر، تمثال القوة، معمل صهر الحديد، المخزون الاحتياطي، برج الرماة، برج القصف",
                        "youwillunlock":"مركز التجنيد، مركز الأخبار، فخ المسامير، جدار"
