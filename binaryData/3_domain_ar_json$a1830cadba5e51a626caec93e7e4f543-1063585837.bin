    "quest":{
        "10":{
            "brag":"خطوة صغيرة بالنسبة لمدينتك، لكنها قفزة كبيرة للبشرية.",
            "title":"الأهم فالمهم"
        },
        "100":{
            "brag":"إنتاجي من الحجر في تحسن. ماذا عن إنتاجك؟",
            "title":"بدايات متواضعة"
        },
        "1000":{
            "brag":"ثروة من الخشب والحجر! الأقضل لك اللحاق! أنا متقدم!",
            "title":"لمزيد من الإنتاجية"
        },
        "1100":{
            "brag":"وفرة القوة والحديد هي أهم شيء بالنسبة للمرتزقة. عليك أن تحترس! سأتسلق نحو القمة!",
            "title":"من أجل جيشٍ أفضل"
        },
        "1200":{
            "brag":"تم إرسال واستلام 10 مرتزقة إلى نقطة مراقبة أحد الحلفاء. الإخوة! لا تتركني من دون جدوى.",
            "title":"مرتزقة ودودون"
        },
        "125":{
            "brag":"مرتزقتي أفضل تجهيزاً الآن! هل تعتقد أنه يمكنك مضاهاة قوتهم؟",
            "title":"جيش مجهز بشكل أفضل"
        },
        "1300":{
            "brag":"سريع لكن ضعيف. إلا أنه لا يمكن لأي مرتزق حتى الآن أن يُلحق الدمار كما يفعلون هم ... حتى الآن.",
            "title":"تجنيد القتلة"
        },
        "1400":{
            "brag":"شكّل عصابتك الخاصة في لعبة \"حرب المرتزقة\"، إذا لم تفعل ذلك فلن تجد أحداً يقف بجانبك!",
            "title":"شخصية مغناطيسية"
        },
        "1500":{
            "brag":"الموارد هي المفتاح... لكل شيء! قريباً سأكون أفضل منك!",
            "title":"خزن المزيد من الموارد"
        },
        "1600":{
            "brag":"المزيد من المرتزقة يعني المزيد من الغنائم! احذر من أعدادي!",
            "title":"ابن المزيد من الثكنات"
        },
        "1700":{
            "brag":"الحذر الشديد لا يضر. جمّع الدفاعات فوق بعضها البعض إذا كنت تريد البقاء على قيد الحياة!",
            "title":"الدفاع أولاً ودائماً"
        },
        "1800":{
            "brag":"الكاميكازيون معروفون بأنهم يبالغون كثيراً! بالنسبة لي، الجدران لم تعد مشكلة!",
            "title":"قوة البارود!"
        },
        "1900":{
            "brag":"عربات الخشب والحجارة تصل بالمئات، المباني لديّ أقوى. كيف حالك؟",
            "title":"البناء بسرعة"
        },
        "20":{
            "brag":"لقد كنت على وشك!",
            "title":"في الوقت المناسب بالضبط!"
