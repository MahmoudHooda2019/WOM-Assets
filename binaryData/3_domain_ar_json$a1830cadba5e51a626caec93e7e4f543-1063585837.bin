            "11":{
                "desc":"ينتج الخشب. يستخدم في تشييد المباني.",
                "name":"منجرة"
            },
            "12":{
                "desc":"تنتج الحجارة. يستخدم في تشييد المباني.",
                "name":"محجر"
            },
            "13":{
                "desc":"يمنح القوة المستخدمة في تحرير المرتزقة وتطويرهم وقدراتهم الخاصة وهجماتهم.",
                "name":"تمثال القوة"
            },
            "14":{
                "desc":"ينتج الحديد. يستخدم لتوظيف المرتزقة.",
                "name":"صاهر الحديد"
            },
            "15":{
                "desc":"هذا هو ما يحمل الموارد التي تم جمعها أثناء تكدسها. يتطلب إنتاج هذا استخدام الخشب والحجارة.",
                "name":"المخزون الاحتياطي"
            },
            "17":{
                "desc":"اعثر على مرتزقة جدد وجنّدهم!",
                "function":"كل مستوى يتيح تجنيد أنواع جديدة من المرتزقة",
                "name":"مركز التجنيد"
            },
            "18":{
                "desc":"ضع الإحصائيات المختلفة للمرتزقة الذين لديك. درّبهم حتى يصبحوا هم آلات القتل الحاسمة!",
                "function":"كل تطوير بسمح بمستويات تدريب جديدة وتتيح تدريب مرتزقة من طبقة أعلى.",
                "name":"مركز التدريب"
            },
            "19":{
                "desc":"منزل مرتزقتك بعد إكمالهم التدريب بنجاح. كلما كانت هذه أكثر وأفضل كان بإمكانك تسكين المزيد من المرتزقة. احذر، إذا احترق فسوف يحترق كل من بداخله أيضًا!",
                "name":"ثكنات المرتزقة"
            },
            "20":{
                "desc":"يتم توظيف (إنتاج) المرتزقة في هذا المبنى.",
                "function":"كل تطوير يقدم مرتزقة جدد ليتم تجنيدهم.",
                "name":"منطقة التوظيف"
            },
            "21":{
                "desc":"اجعل كل أعمال توظيف المرتزقة في مكانٍ واحد! يساعدك في عملية توظيف المرتزقة، ويتحكم في جميع مناطق التوظيف، ويوجه المرتزقة إلى المنطقة المتاحة بمجرد أن يأخذوا دورهم في قائمة الانتظار.",
                "name":"إدارة التجنيد المركزي"
            },
            "22":{
                "desc":"يسمح لك بمهاجمة المدن الأخرى والانتصار! استخدم \"غرفة الخرائط\" للعثور على فريستك القادمة.",
                "function":"كل تطوير يزيد من حجم المرتزقة الذين يمكنك نشرهم بنقرة واحدة.",
                "name":"منطقة التجميع"
            },
            "23":{
                "desc":"أفضل سلاح للاستيلاء على مدينة العدو. ألق الأشياء في ميدان العدو لتدمير المباني من أعلى. لا تنس تطوير هذا المبنى لزيادة المدى والقوة.",
                "function":"كل تطوير يتيح لك نشر نوع آخر من الصواريخ.",
                "name":"المنجنيق"
            },
            "24":{
                "desc":"أنت لست وحدك في هذه الأرض المجهولة، اعثر على الأصدقاء وهاجم الأعداء باستخدام التلسكوب.",
                "function":"كل تطوير يتيح لك نوعاً جديداً من الصواريخ وحجم أكبر للصواريخ.",
                "name":"تلسكوب قديم"
            },
            "25":{
                "desc":"يتيح لك اختبار مستوى الحماس في مدينتك - لنرى إذا ما كانت هذه الدفاعات سوف تصمد عند جذب الوحوش البرية! إذا كنت في موقف صعب، يمكنك دائماً إيقاف الهجوم الذاتي.",
                "name":"بوق الحرب"
            },
            "26":{
                "desc":"يتيح لك رؤية المدينة بأكملها لكي تخطط دفاعاتك ومبانيك من مكان مرتفع.",
                "name":"مخطط المدينة"
            },
            "27":{
                "desc":"يتيح لك التخلص من أولئك المرتزقة غير المرغوب فيهم وغير الخاضعين للسيطرة. المتمرد سيكون وقوداً للمخلص! الضعيف يجب أن يتنحى من أجل القوي!",
                "function":"كل تطوير يعيدحديداً أكثر عند إعدام المرتزقة.",
                "name":"المقصلة"
            },
            "28":{
                "desc":"يتيح لك معرفة مدينتك إذا كنت لا تُشرف عليها شخصياً.",
                "name":"مركز الأخبار"
            },
            "29":{
                "desc":"الكهف هو موطن الوحوش القاتلة: اليعسوب والمايتوسور والدب المذؤوب! يمكنك الإبقاء على وحوشك البرية تحت السيطرة في هذه الغرفة.",
                "name":"كهف الوحوش"
            },
            "30":{
                "desc":"يتيح لك وضع الوحوش في أقفاص، 3 في كل مرة، مما يسمح لك بتغيير الوحش المهاجم وحماية البقية من الهجوم.",
                "name":"حارس الوحوش"
            },
            "31":{
                "desc":"سيبذل هؤلاء الرماة أقصى جهدهم للقضاء على الأعداء في الجو وعلى الأرض! احذر من المدى الطويل، والقوة الكبيرة، والبطء في إعادة التحميل.",
                "name":"برج الرماة"
            },
            "32":{
                "desc":"مدى قصير وعريض وغير كافٍ! سوف يسحق تماماً الأعداء الضعفاء على الأرض! لكنه ممتاز لتدمير المرتزقة المعبئين بإحكام!",
                "name":"برج القصف"
            },
            "33":{
                "desc":"إنها نيران، وسوف تحرق أعداءك حتى تجعلهم رماداً. أنت تشعل الوقود، وتضغط وتطلقها مع شرارة! جراحة تجميلية قاتلة لأعدائك.",
                "name":"برج اللهب"
            },
            "34":{
                "desc":"أدر الرافعة، وشاهد السهام وهي تطير! ماكينة السهام المذهلة هذه لا تتوقف أبداً!",
                "name":"برج رمي السهام"
            },
            "35":{
                "desc":"تحية لدستة رماح الموت! الأعداء الذين في الجو يجب أن يحذروا من هذه المجموعة الحادة من الرماح التي تنطلق بسرعة البرق!",
                "name":"برج الدفاع الجوي"
            },
            "36":{
                "desc":"أشعة شمسية مركزة لتسليط الضوء على جميع أعدائك في صفٍ واحد!",
                "name":"المرايا الحارقة"
            },
            "37":{
                "desc":"الدفاع أم الهجوم؟ لماذا لا تجمع بين الاثنين؟ هذا المبنى الدفاعي يسمح لك بإخفاء مرتزقة الحماية الذين سيتم إطلاقهم للرد بدون رحمة على أي هجوم.",
                "name":"نقطة المراقبة"
            },
            "38":{
                "desc":"لماذا لا تدع حلفاءك يتولون مسؤولية دفاعاتك؟ اطلب منهم أن يرسلوا إليك بعض المرتزقة المدافعين!",
                "name":"نقطة مراقبة الحلفاء"
            },
            "39":{
                "desc":"فخ متفجر سيخترق قوات العدو من أسفل ويطعنهم! ضع هذه بالقرب من مبانيك أو صمم الجدران بحيث توجه الوحدات المهاجمة نحو هذه الفخاخ القاتلة غير المرئية.",
                "name":"المسامير المدفونة"
            },
            "40":{
                "desc":"هذه الفخاخ ستحرق فقط أقوى الأعداء وتحولهم إلى رماد وتلحق ضرراً بالأماكن المحيطة بها.",
                "name":"الفخ الناري"
            },
            "41":{
                "desc":"سياج وجدران واقية لـ... احم مدينتك! لا تنس تطوير هذه الجدران الخشبية على طول الطريق المؤدي إلى الجدار البركاني!",
                "name":"الحائط"
            },
            "42":{
                "desc":"مقر الحلف هو مركز تحالفك. وهو مطلوب لإقامة التحالفات والانضمام إليها. يمكنك استعراض التحالفات ومشاهدة أعضائها ومختلف الإحصائيات الخاصة بهؤلاء الأعضاء.",
                "name":"مقر الحلف"
            },
            "43":{
                "desc":"مقر تعزيزاتك التي يرسلها رفاقك في الحلف! كلما كان المستوى أعلى استطعت أن تسكّن عددًا أكبر من المرتزفة. واحذر لأنه إذا احترق فسوف يحترق كل ما بداخله أيضًا.",
                "name":"ثكنات الحلف "
            }
        },
