            "title":"Raise Bearwolf in the Beast Cave"
        },
        "48003":{
            "hint":"You can deploy your Bearwolf in battle, from the command buttons on the left-hand side while you're at an enemy city.",
            "title":"Deploy Bearwolf in a battle"
        },
        "49001":{
            "hint":"Look for merc requirements of beast trainings in the Beast Cave",
            "title":"Train your Beast twice in the Beast Cave"
        },
        "49002":{
            "hint":"Your Beast has to be damaged in order to get healed, so make it spill some blood first!",
            "title":"Heal your Beast in the Beast Cave using Gold."
        },
        "50001":{
            "hint":"Towers can be built via \"Defense\" tab under the Buildings Menu",
            "title":"Build 2 Sky Towers"
        },
        "50002":{
            "hint":"Click on any tower to see the upgrade option.",
            "title":"Have 12 Towers at level 4 or higher."
        },
        "5001":{
            "hint":"The Stock Pile can be found in the Building Menu under the \"Resource\" tab.",
            "title":"Build a Stock Pile"
        },
        "5002":{
            "hint":"You can also Harvest All resources with a single click by clicking on a Stock Pile.",
            "title":"Harvest resources using the \"harvest all\" ability by clicking on a Stock Pile"
        },
        "51001":{
            "hint":"You can recruit Gentle Healer in the Recruitment Chamber building. Once recruited you will be able to hire them for war in the Hiring Quarters.",
            "title":"Recruit Gentle Healer in the Recruitment Chamber"
        },
        "51002":{
            "hint":"Like any merc, you can hire Gentle Healer in the Hiring Quarters.",
            "title":"Hire 1 Gentle Healers"
        },
        "52001":{
            "hint":"House of Brotherhood can be found in the Building Menu under the \"Functional\" tab.",
            "title":"Build a House of Brotherhood"
        },
        "52002":{
            "hint":"Enter the House of Brotherhood to see the \"Create Union\" option.",
            "title":"Create a Brotherhood and invite 5 friends to your Union"
        },
        "53001":{
            "hint":"Watch Post can be found in the Building Menu under the \"Defense\" tab.",
            "title":"Build a Watch Post"
        },
        "53002":{
            "hint":"Enter the Watch Post to transfer your Mercs.",
            "title":"Put 10 Mercs into the Watch Post"
        },
        "54001":{
            "hint":"You can recruit Hezarfen in the Recruitment Chamber building. Once recruited you will be able to hire them for war in the Hiring Quarters.",
            "title":"Recruit Hezarfen in the Recruitment Chamber"
        },
        "54002":{
            "hint":"Target stronger opponents for higher loots!",
            "title":"Loot 500.000 resources in a single battle"
        },
        "55001":{
            "hint":"Beast Keeper can be found in the Building Menu under the \"Defense\" tab.",
            "title":"Build a Beast Keeper"
        },
        "55002":{
            "hint":"Enter the Beast Keeper to see the option.",
            "title":"Cage your Beast in the Beast Keeper"
        },
        "56001":{
            "hint":"Enter the Beast Cave to begin hiring",
            "title":"Raise Mightosour in the Beast Cave"
        },
        "56002":{
            "hint":"Keep your Beast training until you reach level 2",
            "title":"Upgrade the Mightosour to level 2"
        },
        "57001":{
            "hint":"Click on War button to enter War Room. You can see and attack  Bandit Clans in the map view or list view here.",
            "title":"Gain 5 victories against Clans."
        },
        "58001":{
            "hint":"Invite other players from the Brotherhood Building to join your cause",
            "title":"Have 10 players in your Brotherhood"
        },
        "58002":{
            "hint":"Visit your friends' towns and help them out!",
            "title":"Gain 500 RP by helping your friends"
        },
        "58003":{
            "hint":"Don't forget to gift them back!",
            "title":"Collect 100 items from friends"
        },
        "59001":{
            "hint":"Recruit Persian Sapper the Recruitment Chamber building. Once unlocked you will be able to produce them in the Hiring Quarters",
            "title":"Recruit Persian Sapper in the Recruitment Chamber"
        },
        "59002":{
            "hint":"Like any merc, you hire Persian Sappers in the Hiring Quarters.",
            "title":"Hire 2 Persian Sappers"
        },
        "59003":{
            "hint":"More buildings also mean more towers! Be prepared for a though battle!",
            "title":"Destroy 25 buildings in a single battle"
        },
        "60001":{
            "hint":"Make sure you train your Mightosour what it needs to grow big and strong.",
            "title":"Evolve the Mightosour to level 6"
        },
        "60002":{
            "hint":"Make sure you train your Bearwolf what it needs to grow big and strong.",
            "title":"Evolve the Bearwolf to level 6"
        },
        "6001":{
            "hint":"Click on Upgrade in Main Menu and then on City Center to upgrade the building. You can speed up the process once it is started.",
            "title":"Upgrade your City Center to level 2"
        },
        "601":{
            "hint":"Click on the Lumber Blade to harvest the gathered Lumber.",
            "title":"Harvest 50 Lumber"
        },
        "602":{
            "hint":"Click on Upgrade in Main Menu and then on Lumber Blade to upgrade the building. You can speed up the process once it is started.",
            "title":"Upgrade a Lumber Blade to Level 2"
        },
        "61001":{
            "hint":"Unlock Rock'n Gaul in the Recruitment Chamber building. Once unlocked you will be able to produce them in the Hiring Quarters",
            "title":"Recruit Rock'n Gaul in the Recruitment Chamber"
        },
        "61002":{
            "hint":"Towers mean trouble! Get a decent attack force first.",
            "title":"Destroy 10 Towers in a single battle"
        },
        "62001":{
            "hint":"Build the Beast Cave hatch Dragonfly",
            "title":"Raise The Dragonfly in the Beast Cave"
        },
        "62002":{
            "hint":"Make sure you train your Dragonfly what it needs to grow big and strong.",
            "title":"Evolve The Dragonfly to level 6"
        },
        "62003":{
            "gototext":"Show me",
            "hint":"Try to find a town with only a few defensive structures. Your Dragonfly is strong, but not immortal!",
            "title":"Destroy a friend's City Center only by deploying the Dragonfly"
        },
        "7001":{
            "gototext":"Show me",
            "hint":"Invite friends that you think will love War of Mercenaries and start playing!",
            "title":"Have 1 Friend playing War of Mercenaries"
        },
        "7002":{
            "hint":"Click on a friend's photo, from the list at the bottom of your screen, to visit them.",
            "title":"Gain 2 RP by helping a friend"
        },
        "701":{
            "hint":"Extra Workers allow you to build more buildings simultaneously. Enter Store to buy one.",
            "title":"Collect Worker Tools"
        },
        "8001":{
            "hint":"The Recruitment Chamber can be found in the Building Menu under the \"Functional\" tab.",
            "title":"Build a Recruitment Chamber"
        },
        "8002":{
            "hint":"You can recruit Janissary in the Recruitment Chamber building. Once recruited you will be able to hire them for war in the Hiring Quarters.",
            "title":"Recruit Janissary in the Recruitment Chamber"
        },
        "8003":{
            "gototext":"Show me",
            "hint":"Click on War button and then Campaign to locate a nearby Raging Bull Clan. You can scout the enemy city before initiating attack.",
            "title":"Attack and take down a Raging Bull City Center"
        },
        "801":{
            "gototext":"Show me",
            "hint":"Click on Thorzain's picture in the friend bar and select \"help\"",
            "title":"Visit Thorzain's city"
        },
        "802":{
            "hint":"Click on buildings with icons on them to help friends",
            "title":"Help Thorzain 4 times."
        },
        "8501":{
            "hint":"You can hire Bedouin Brutes in the Hiring Quarters. Once hired, the Mercs will be ready for defense or attack duty.",
            "title":"Hire 10 Bedouin Brutes"
        },
        "8502":{
            "hint":"You can hire Janissaries in the Hiring Quarters. Once hired, the Mercs will be ready for defense or attack duty.",
            "title":"Hire 3 Janissaries"
        },
        "8503":{
            "gototext":"Show me",
            "hint":"Click on the War button and then Campaign to locate the nearby Demon King Clan. You can scout the enemy city before initiating attack.",
            "title":"Attack and take down a Demon King Clan's City Center"
        },
        "9001":{
            "hint":"You can recruit Night Rider in the Recruitment Chamber building. Once recruited you will be able to hire them for war in the Hiring Quarters.",
            "title":"Recruit Night Rider in the Recruitment Chamber"
        },
        "9002":{
            "hint":"You can recruit Night Rider in the Recruitment Chamber building. Once recruited you will be able to hire them for war in the Hiring Quarters.",
            "title":"Hire 1 Night Rider"
        },
        "9003":{
            "gototext":"Show me",
            "hint":"Click on the War button and then Campaign to locate a nearby Iron Hand Clan. You can scout the enemy city before initiating attack.",
            "title":"Attack and take down an Iron Hand City Center"
        }
    },
    "tutorial":{
        "done":"Ok",
        "step":{
            "1":{
                "desc":"Quick Sire! \nBandit Clans are on the attack; let’s take cover!",
                "done":"OK"
            },
            "10":{
                "desc":"Some mercenaries joined our cause."
            },
            "11":{
                "desc":"Well defended!\nLet's get revenge on the bandits that attacked you!"
            },
            "11b":{
                "desc":"Enemy is camping outside our City. Let's go and crush them!"
            },
            "14-alt":{
                "desc":"This city has only a few defenses. Let's attack!"
            },
            "14":{
                "desc":"This city has no defenses.\nLet's attack!",
                "done":"HELL YEAH!"
            },
            "15-alt":{
                "desc":" Click \"+\" button to select mercenaries."
            },
            "15-alt2":{
                "desc":"Click to select mercenaries."
            },
            "15":{
                "desc":"Click & Hold\n  \"+\" \nbutton to select \nmercenaries."
            },
            "16":{
                "desc":"Click here to deploy the Mercenaries!"
            },
            "18":{
                "desc":"Click on resource producers \nto collect resources."
            },
            "19":{
                "desc":"Now let's upgrade a building!"
            },
            "1b":{
                "desc":"Welcome Sire! It is time for these lands to see glorious days again!",
                "done":"LET'S START"
            },
            "2":{
                "desc":"Let’s build an Archer’s Tower to defend your city."
            },
            "22":{
                "desc":"Click on the building to speed up the process."
            },
            "25":{
                "desc":"Here is our first quest.\nClick on it to continue."
            },
            "29":{
                "desc":"Place your hiring quarters as you desire."
            },
            "32":{
                "desc":"This construction takes 15 minutes.\nLet's speed through it."
            },
            "34":{
                "desc":"Now let's hire some Mercenaries!"
            },
            "36":{
                "desc":"Click on the picture 4 times to hire Bedouin Brutes."
            },
            "37":{
                "desc":"We'll wait for hirings to complete. You can speed up the process in the Hiring Quarters if you don't want to wait."
            },
            "39":{
                "desc":"Well done!\nLet's hire a worker to build more.\n"
            },
            "43":{
                "desc":"You are protected from attacks for a while.\nThe timer at the top shows the duration.",
                "done":"GOT IT!"
            },
            "44":{
                "desc":"Follow the quests to get ahead. \nGood luck!",
                "done":"LEAVE ME!"
            },
            "45":{
                "desc":"Click on buildings with red RP icons. If you help 4 times, you'll be awarded with 4 RP's!",
                "done":"GREAT"
            },
            "46":{
                "desc":"We found a precious item during battle. Let's have a look at it!"
            },
            "47":{
                "desc":"This is a wooden plank! These parts will come in handy when you build resource producers. ",
                "done":"REALLY?"
            },
            "5":{
                "desc":"Now, place it here."
            },
            "55-1":{
                "done":"GOT IT!"
            },
            "55-2":{
                "done":"GOT IT!"
            },
            "55":{
                "desc":"This shows your current RP. You can use it to buy items from the Store. Go help friends to gain RP!"
            },
            "56":{
                "desc":"Mercs you deploy won't come back after battle, even if they survive. Don't deploy more Mercs than you need.",
                "done":"GOT IT!"
            },
            "57":{
                "desc":"Don't worry; everything will be good as new soon. Just start the repairs!"
            },
            "58":{
                "desc":"Your stock is full and your resources cannot be harvested. Build & upgrade Stock Piles or buy Stock Pile boost."
            },
            "59":{
                "desc":"You've just unlocked a looter-type merc! These mercs loot almost 6 times more when attacking Stockpiles and City Centers."
            },
            "60-1":{
                "done":"SOUNDS EASY!"
            },
            "60-2":{
                "done":"SOUNDS EASY!"
            },
            "60":{
                "desc":"You can collect parts in 3 ways: clicking on friends' posts, sending them requests or destroying players' City Centers!"
            },
            "61":{
                "desc":"You are doing great Sire! Destroy enemy to earn more badges!",
                "done":"GREAT!"
            },
            "62":{
                "desc":"You can see all friends and other players on your map and in the list.",
                "done":"OK"
            },
            "63":{
                "desc":"You can also attack and loot vulgar Bandit Clans in Campaign mode!",
                "done":"GOT IT!"
            },
            "64":{
                "desc":"Dealing damage gives Battle Points; more damage means more Battle Points. Attacking friends and Clans do not contribute to your points.",
                "done":"GOT IT!"
            },
            "65":{
                "desc":"You've just unlocked a tank-type merc! Send them first so they attack towers and towers attack them! Then let your Bedouins do the rest."
            },
            "6b":{
                "desc":"Click to FREE FINISH instantly."
            },
            "9":{
                "desc":"Whoa, here come some bandits!\nDon't worry; we're well prepared!",
                "done":"I'M READY!"
            }
        }
