    "speech":{
        "workerconstructionstart":[
            "I’m too old for this s**t.",
            "Work work"
        ],
        "workerfortifystart":[
            "You’re ruining my day.."
        ],
        "workeridle":[
            "I used to be a mercenary, then I took an arrow to the knee.",
            "Boooring.....",
            "So much time to waste..",
            "Just give me a job, will ya?",
            "Let’s play cards..",
            "Go get me a job!",
            "I want to resign!",
            "Will work for food"
        ],
        "workerupgradestart":[
            "Can’t get enough eh?"
        ]
    },
