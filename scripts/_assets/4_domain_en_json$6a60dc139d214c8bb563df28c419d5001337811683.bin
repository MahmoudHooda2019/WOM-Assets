    "domain":{
        "beasts":{
            "25":{
                "desc":"The deadly heat of the desert and his merciless master forged the mightiest creature to rule the skies in flames. Legends and stories tell of huge fireballs leaving a trail of death on the battlefield, but no one can confirm its existence as it left no surviving enemy mercenary yet.",
                "name":"Dragonfly",
                "title":"Powers Up Other Mercs"
            },
            "26":{
                "desc":"Driven by it's master's ruthless whip, there's almost no living thing this monster can't trample. Its huge body forms an unrivalled defensive challenge and its wicked tusks can annihilate any threat in a matter of seconds.",
                "name":"Mightosour",
                "title":"High Attack"
            },
            "27":{
                "desc":"This mythic icon of Rome dominates the battleground with its swordlike claws and razor sharp teeth. The balanced qualities of this beast make it an excellent all-purpose battle unit that every warlord wants to possess.",
                "name":"Bearwolf",
                "title":"High Defense"
            },
            "33":{
                "desc":"Coming from the endless jungles of Africa, Wom-Kong can attack air and ground units from a distance and devastates enemies with its deadly bananas.",
                "name":"Wom-Kong",
                "title":"Ranged Attack"
            }
        },
        "building":{
            "10":{
                "desc":"The gathering place for your resources, the gate to new technologies, and your city's heart. If taken, your city falls!",
                "name":"City Center",
                "perlevel":{
                    "10":{
                        "youwillbeabletobuildmore":"-",
                        "youwillbeabletoupgradeyour":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter",
                        "youwillunlock":"-"
                    },
                    "2":{
                        "youwillbeabletobuildmore":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Archer's Tower, Bombard Tower, Hiring Quarters",
                        "youwillbeabletoupgradeyour":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Archer's Tower, Bombard Tower",
                        "youwillunlock":"Recruitment Chamber, Pigeon Post, Buried Spikes, Wall"
                    },
                    "3":{
                        "youwillbeabletobuildmore":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Mercenary Barracks, Archer's Tower, Bombard Tower, Buried Spikes, Wall, Hiring Quarters, Training Chamber, ",
                        "youwillbeabletoupgradeyour":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Recruitment Chamber, Mercenary Barracks, Assembly Area, Archer's Tower, Bombard Tower, Wall, Hiring Quarters",
                        "youwillunlock":"City Planner, Executional Guillotine, Catapult, Central Hiring, Watch Post"
                    },
                    "4":{
                        "youwillbeabletobuildmore":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Training Chamber, Archer's Tower, Bombard Tower, Buried Spikes, Wall, Hiring Quarters",
                        "youwillbeabletoupgradeyour":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Recruitment Chamber, Training Chamber, Assembly Area, Archer's Tower, Bombard Tower, Watchpost, Wall, Catapult, Hiring Quarters",
                        "youwillunlock":"Flamer Tower, Gatling Arrow Tower, Sky Tower, Beast Cave, Beast Keeper, Fire Trap"
                    },
                    "5":{
                        "youwillbeabletobuildmore":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Mercenary Barracks, Archer's Tower, Bombard Tower, Flamer Tower, Gatling Arrow Tower, Sky Tower, Watchpost, Buried Spikes, Fire Trap, Wall, Hiring Quarters",
                        "youwillbeabletoupgradeyour":"Lumber Blade, Stone Grinder, Statue of Might, Iron Smelter, Stock Pile, Recruitment Chamber, Training Chamber, Mercenary Barracks, Archer's Tower, Bombard Tower, Flamer Tower, Gatling Arrow Tower, Sky Tower, Watchpost, Wall, Catapult",
                        "youwillunlock":"Burning Mirrors"
                    },
                    "6":{
                        "youwillbeabletobuildmore":"Flamer Tower, Gatling Arrow Tower, Buried Spikes, Fire Trap, Wall",
                        "youwillbeabletoupgradeyour":"Training Chamber, Mercenary Barracks, Archer's Tower, Bombard Tower, Flamer Tower, Gatling Arrow Tower, Sky Tower, Burning Mirrors, Wall, Catapult",
                        "youwillunlock":" "
                    },
                    "7":{
                        "youwillbeabletobuildmore":"Buried Spikes, Fire Trap, Wall",
                        "youwillbeabletoupgradeyour":"Flamer Tower, Gatling Arrow Tower, Sky Tower, Burning Mirrors",
                        "youwillunlock":"-"
                    },
                    "8":{
                        "youwillbeabletobuildmore":"Mercenary Barracks, Watch Post, Buried Spikes, Fire Trap, Wall",
                        "youwillbeabletoupgradeyour":"Flamer Tower, Burning Mirrors, Watchpost",
                        "youwillunlock":"-"
                    },
                    "9":{
                        "youwillbeabletobuildmore":"Stock Pile, Buried Spikes, Fire Trap, Wall",
                        "youwillbeabletoupgradeyour":"Flamer Tower, Gatling Arrow Tower, Sky Tower, Burning Mirrors, Watchpost",
                        "youwillunlock":"-"
                    }
                }
            },
            "11":{
                "desc":"Produces Lumber. Used in the construction of buildings.",
                "name":"Lumber Blade"
            },
            "12":{
                "desc":"Produces Stone. Used in the construction of buildings.",
                "name":"Stone Grinder"
            },
            "13":{
                "desc":"Produces Might used for unlocking and upgrading mercenaries & their special abilities and attacks.",
                "name":"Statue of Might"
            },
            "14":{
                "desc":"Produces Iron. Used for hiring mercenaries!",
                "name":"Iron Smelter"
            },
            "15":{
                "desc":"This is what holds the gathered resources as it bulges up. The production of this requires Lumber & Stone.",
                "name":"Stock Pile"
            },
            "17":{
                "desc":"Find and recruit new mercenaries!",
                "function":"Each level enables new types of mercenaries to be recruited",
                "name":"Recruitment Chamber"
            },
            "18":{
                "desc":"Develop your mercenaries' different stats. Train them, so they become the ultimate killing machines!",
                "function":"Each upgrade unlocks new training levels and enables the training of higher tier Mercs.",
                "name":"Training Chamber"
            },
            "19":{
                "desc":"Home of your mercenaries after they survive training! The better and plentier these are, the more mercenaries you can house. Be careful, if it burns - all within burn too!",
                "name":"Mercenary Barracks"
            },
            "20":{
                "desc":"Mercs are hired (produced) in this building.",
                "function":"Each upgrade introduces new mercenaries to be recruited.",
                "name":"Hiring Quarters"
            },
            "21":{
                "desc":"Centralize all your Mercenary hiring! Helps you in Mercenary hiring process, and controls all your Hiring Quarters, forwarding your Merc to whichever quarter is available once in the queue!",
                "name":"Central Hiring"
            },
            "22":{
                "desc":"Let's you attack other cities and be victorious! Use the Map Room to find your next prey.",
                "function":"Each upgrade increases the amount of Mercs you can deploy with a single click.",
                "name":"Assembly Area"
            },
            "23":{
                "desc":"The perfect weapon to take over an enemy City. Hurl things into the enemy field to destroy buildings from above. Don't forget to upgrade this building to increase damage.",
                "function":"Each upgrade enables you to deploy another type of salvo.",
                "name":"Catapult"
            },
            "24":{
                "desc":"You are not alone in this uncharted territory, find friends and attack enemies with the Telescope.",
                "function":"Each upgrade enables a new salvo type and a bigger salvo size.",
                "name":"Ancient Telescope"
            },
            "25":{
                "desc":"Lets you test the mettle of your City- let us see if these defenses will hold by attracting Wild Savages! If you are way above your head, you can always call off the self-inflicted attack.",
                "name":"Tusk Horn"
            },
            "26":{
                "desc":"Lets you see your whole City to better plan your defenses and buildings from up high.",
                "name":"City Planner"
            },
            "27":{
                "desc":"Lets you get rid of those unwanted uncontrollable mercenaries. The disobedient shall feed the devoted! The weak should give room to the strong!",
                "function":"Each upgrade returns more iron when executing Mercs.",
                "name":"Executional Guillotine"
            },
            "28":{
                "desc":"Lets you know about your city if you're not personally supervising it!",
                "name":"Pigeon Post"
            },
            "29":{
                "desc":"The Cave is home to the deadly beasts: Dragonfly, Mightosour and Bearwolf! You can keep your wild Beasts on a tight leash in this chamber.",
                "name":"Beast Cave"
            },
            "30":{
                "desc":"Lets you cage your beasts, 3 at a time, allowing you to change your attacking Beast and protect the rest from attack.",
                "name":"Beast Keeper"
            },
            "31":{
                "desc":"These Archers will do their best to take down aerial and ground enemies! Beware of the long range, high damage, but the slow reload.",
                "name":"Archer's Tower"
            },
            "32":{
                "desc":"Short, stubby, not enough range! It will still smash weak ground enemies to a pulp! But great for destroying tightly-packed Mercs!",
                "name":"Bombard Tower"
            },
            "33":{
                "desc":"It is fire, and will burn your enemies to a crisp well done state. You ignite the fuel, pressurize and shoot it with a spark! Fatal plastic surgery for your enemies.",
                "name":"Flamer Tower"
            },
            "34":{
                "desc":"Turn the lever, watch the arrows fly! This incredible arrow machine doesn't ever stop!",
                "name":"Gatling Arrow Tower"
            },
            "35":{
                "desc":"All hail the dozen spears of death! Airborne enemies should beware of this sharp, lightning-speed cluster of spears!",
                "name":"Sky Tower"
            },
            "36":{
                "desc":"Concentrated sun to light up your enemies in a row!",
                "name":"Burning Mirrors"
            },
            "37":{
                "desc":"Defense or Offense? Why not combine the two? This defense building allows you to disguise your protective Mercs, who will be unleashed to respond mercilessly to any attack.",
                "name":"Watch Post"
            },
            "38":{
                "desc":"Why not let your allies manage your defenses? Invite them to send you some defensive Mercs!",
                "name":"Friend Watch Post"
            },
            "39":{
                "desc":"A booby trap that will spike the enemy forces from below and impale them! Place these near your buildings or design your walls to tunnel attacking units towards these invisible death traps.",
                "name":"Buried Spikes"
            },
            "40":{
                "desc":"These traps will burn only the most powerful of enemies to a cinder and cause splash damage to its surroundings.",
                "name":"Fire Trap"
            },
            "41":{
                "desc":"Protective fence and walls to... Protect your City! Don't forget to upgrade these wooden walls all the way up to Obsidian!",
                "name":"Wall"
            },
            "42":{
                "desc":"House of Brotherhood is the center of your Alliance. It is required for creating and joining Alliances. You can browse through Alliances, view their members and see the members' various statistics.",
                "name":"House of Brotherhood"
            },
            "43":{
                "desc":"Home of your reinforcements, sent by your alliance brothers! The higher level, the more mercenaries you can house. Be careful, if it burns - all within burn too!",
                "name":"Alliance Barracks"
            },
            "44":{
                "desc":"You can prepare unlocked Event Rewards in this building.",
                "name":"Blacksmith"
            },
            "45":{
                "desc":"Attacks only beasts. Has 20 ammo, reloads 1 ammo in 30 mins.",
                "name":"Beast Cannon"
            }
        },
