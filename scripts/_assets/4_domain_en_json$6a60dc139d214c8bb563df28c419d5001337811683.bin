            "title":"Rock'n Gaul Destruction"
        },
        "6200":{
            "brag":"Congratulations, you have reached the end of the quest chain!",
            "title":"Dragonfly Rampage"
        },
        "70":{
            "brag":"Lets craft some nuts out of stone",
            "title":"Workaround"
        },
        "700":{
            "brag":"Having friends does not hurt anyone, especially when playing WoM!",
            "title":"All for One!"
        },
        "80":{
            "brag":"There's a whole universe ahead of me!",
            "title":"One for All!"
        },
        "800":{
            "brag":"Towers will fall in Janissaries' wake! Be prepared!",
            "title":"Janissaries Have Arrived"
        },
        "850":{
            "brag":"Think YOU can field many Mercs? think again!",
            "title":"Combined Arms"
        },
        "900":{
            "brag":"They steal loot from YOU, to give them to me! ",
            "title":"Loot Specialists"
        }
